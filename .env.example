# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# Bedrock LLM Models
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_SONNET_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# ─────────────────────────────────────────────────────────────────────────────
# Bedrock Embedding — Cohere Embed English v3 (1024 dims)
# Enable model access in: AWS Console → Bedrock → Model access
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL=cohere.embed-english-v3

# ─────────────────────────────────────────────────────────────────────────────
# Bedrock Knowledge Base
# Run scripts/setup_kb.py to create the KB and get these values,
# OR create manually in: AWS Console → Bedrock → Knowledge Bases
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_KB_ID=                    # e.g. ABCD1234EF (10-char alphanumeric)
BEDROCK_KB_DATA_SOURCE_ID=        # e.g. XY1234ABCD
BEDROCK_KB_S3_BUCKET=             # e.g. meeting-assistant-kb-12345678-prod
BEDROCK_KB_SEARCH_TYPE=HYBRID     # HYBRID | SEMANTIC | KEYWORD
BEDROCK_KB_NUM_RESULTS=8

# ─────────────────────────────────────────────────────────────────────────────
# STT Provider
#   transcribe  — Amazon Transcribe Streaming (cloud, best accuracy, requires AWS)
#   whisper     — faster-whisper local model (offline, privacy-first, good for Mac)
# ─────────────────────────────────────────────────────────────────────────────
STT_PROVIDER=transcribe

# ─────────────────────────────────────────────────────────────────────────────
# Whisper (only used when STT_PROVIDER=whisper)
# Model options: large-v3-turbo | large-v3 | medium | small | base
# Device options: cpu | cuda | mps  (mps = Apple Silicon GPU)
# Compute type:  int8 (fastest CPU) | float16 (GPU) | float32
# Install:       uv sync --extra whisper
# ─────────────────────────────────────────────────────────────────────────────
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BUFFER_SECONDS=4.0
WHISPER_LANGUAGE=en

# ─────────────────────────────────────────────────────────────────────────────
# Amazon Transcribe Streaming (only used when STT_PROVIDER=transcribe)
# ─────────────────────────────────────────────────────────────────────────────
TRANSCRIBE_REGION=us-east-1
TRANSCRIBE_LANGUAGE=en-US

# ─────────────────────────────────────────────────────────────────────────────
# Audio
# ─────────────────────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION_MS=100

# Development: set USE_FAKE_AUDIO=true on cloud VMs with no microphone
USE_FAKE_AUDIO=false
FAKE_AUDIO_PATH=data/test_audio.wav

# ─────────────────────────────────────────────────────────────────────────────
# Owner / SA profile
# Auto-added as the first option in the Speaker Mapping participant dropdown
# so you don't need to add yourself every time you create a meeting.
# Displayed as: "Lastname, Firstname <email>"
# ─────────────────────────────────────────────────────────────────────────────
USER_FIRST_NAME=
USER_LAST_NAME=
USER_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
