# AWS Configuration
AWS_REGION=us-east-1

# Bedrock Model IDs
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_HAIKU_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_SONNET_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0

# Transcribe
TRANSCRIBE_REGION=us-east-1
TRANSCRIBE_LANGUAGE=en-US

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=aws_kb

# Vector dimensions (Titan Embed v2)
VECTOR_SIZE=1024

# Audio
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION_MS=100

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Development: set to "true" to use file-based audio instead of microphone
USE_FAKE_AUDIO=false
FAKE_AUDIO_PATH=data/test_audio.wav
